BLOCK COLUMN1 RADFRAC
    SUBOBJECTS INTERNALS = CS-1
    PARAM NSTAGE=52 ALGORITHM=STANDARD HYDRAULIC=NO MAXOL=25  &
        DAMPING=NONE
    PARAM2 STATIC-DP=YES OLD-SULZER=NO
    COL-CONFIG CONDENSER=TOTAL CA-CONFIG=INT-1
    FEEDS FEED 37
    PRODUCTS D-TOP 1 L / B-BOTTOM 52 L
    P-SPEC 1 100000.
    COL-SPECS MOLE-D=14.25000000 MOLE-RR=4.12
    SPEC 1 MOLE-FRAC 0.99 COMPS=BENZENE STREAMS=D-TOP  &
        SPEC-DESCRIP="BENZENE RECUPERATION"
    SPEC 2 MOLE-FRAC 0.005 COMPS=BENZENE STREAMS=B-BOTTOM  &
        SPEC-DESCRIP="TOLUENE RECOVERY"
    VARY 1 MOLE-D 0. 100.
    VARY 2 MOLE-RR 0. 100.
    REPORT NOHYDRAULIC
    CONVERGENCE EXTRA-ML=2
    INTERNALS CS-1 STAGE1=2 STAGE2=3 P-UPDATE=NO TRAYTYPE=SIEVE  &
        NPASS=1 SYSFAC=1.000000000 OVER-DESIGN=1.000000000  &
        WEIR-HT=50.80000000 <mm> DC-CLEAR=38.10000000 <mm>  &
        DC-WTOP-SIDE=145.1120704 <mm> DC-WBOT-SIDE=145.1120704 <mm>  &
        HOLE-DIAM=12.70000000 <mm> HOLE-AREA=.1000000000  &
        FLOOD-METH=GLITSCH6 DECK-THICK=0.134 <IN>  &
        PCT-FLOOD-FA=80.00000000 AER-PARAM-M=1.000000000  &
        MAX-DC-LOAD=GLITSCH MAX-ACC-DP=2500.000000  &
        MAX-PCT-DCB=100.0000000 MAX-PCT-ENT=10.00000000  &
        MIN-WEIR-LD=4.470981863 MAX-WEIR-LD=117.3721131  &
        MIN-PCT-DCA=.1000000000
    TRAY-SIZE 1 2 3 SIEVE
