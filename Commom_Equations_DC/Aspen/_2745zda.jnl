EDIT INPUT
##1
BLOCK COLUMN1 RADFRAC ;##1
    SUBOBJECTS INTERNALS = CS-1
    PARAM NSTAGE=52 ALGORITHM=STANDARD HYDRAULIC=NO MAXOL=25  &
        DAMPING=NONE
    PARAM2 STATIC-DP=YES OLD-SULZER=NO
    COL-CONFIG CONDENSER=TOTAL CA-CONFIG=INT-1
    FEEDS FEED 30
    PRODUCTS D-TOP 1 L / B-BOTTOM 52 L
    P-SPEC 1 100000.
    COL-SPECS MOLE-D=14.25000000 MOLE-RR=4.12
    SPEC 1 MOLE-FRAC 0.99 COMPS=BENZENE STREAMS=D-TOP  &
